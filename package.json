{
  "name": "casparcg-playlist-automation",
  "version": "1.0.0",
  "description": "Automated playlist controller for CasparCG broadcast server with support for scheduled blocks, live streams, and video-on-demand playback",
  "main": "dist/main.js",
  "bin": "dist/main.js",
  "scripts": {
    "build": "tsc",
    "start": "node dist/main.js",
    "dev": "tsc && node dist/main.js",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage"
  },
  "keywords": [
    "casparcg",
    "broadcast",
    "playout",
    "automation",
    "playlist",
    "video",
    "streaming"
  ],
  "author": "stukenov",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/stukenov/casparcg-playlist-automation.git"
  },
  "dependencies": {
    "casparcg-connection": "^6.3.0",
    "dotenv": "^16.0.0",
    "ffprobe-static": "^3.1.0",
    "fluent-ffmpeg": "^2.1.3"
  },
  "devDependencies": {
    "@types/dotenv": "^8.2.0",
    "@types/ffprobe-static": "^2.0.3",
    "@types/fluent-ffmpeg": "^2.1.26",
    "@types/jest": "^29.5.13",
    "@types/node": "^22.7.0",
    "jest": "^29.7.0",
    "ts-jest": "^29.2.5",
    "typescript": "^5.6.2"
  },
  "engines": {
    "node": ">=14.0.0"
  }
}
